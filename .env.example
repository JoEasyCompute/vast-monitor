# Server
PORT=3000
POLL_INTERVAL_MS=300000

# Vast.ai CLI / API
VAST_CLI_PATH=~/Desktop/dev/vast/vast
VAST_API_URL=https://console.vast.ai/api/v0
VAST_API_KEY_PATH=~/.config/vastai/vast_api_key

# Alerts
ALERT_TEMP_THRESHOLD=85
ALERT_IDLE_HOURS=6
ALERT_COOLDOWN_MINUTES=60
ALERT_HOSTNAME_COLLISION_COOLDOWN_MINUTES=360

# Storage
DB_PATH=./data/vast-monitor.db
DB_SNAPSHOT_RETENTION_DAYS=0
DB_ALERT_RETENTION_DAYS=0
DB_EVENT_RETENTION_DAYS=0

# Optional company/private plugin modules
# Comma-separated paths, relative to project root or absolute
PLUGIN_MODULES=
